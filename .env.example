# ============================================================================
# EMPOWISE PLATFORM - ENVIRONMENT CONFIGURATION
# ============================================================================
# This file contains all configuration needed for the platform to work.
# 
# IMPORTANT: 
# 1. Copy this file to .env (not .env.example)
# 2. Fill in your actual values from your Supabase project
# 3. NEVER commit .env to git - it contains secrets
# 4. Keep .env.example in git as a template for other developers

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Get these from your Supabase project dashboard:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and Anon Key below

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================================
# ZOHO BOOKS INTEGRATION (Optional - for Phase 2)
# ============================================================================
# Only needed when connecting to Zoho Books for invoicing
# VITE_ZOHO_CLIENT_ID=your-zoho-client-id
# VITE_ZOHO_CLIENT_SECRET=your-zoho-client-secret
# VITE_ZOHO_ORGANIZATION_ID=your-zoho-org-id

# ============================================================================
# FLUTTERWAVE INTEGRATION (Optional - for Phase 2)
# ============================================================================
# Only needed for payment processing
# VITE_FLUTTERWAVE_PUBLIC_KEY=your-flutterwave-public-key

# ============================================================================
# APP CONFIGURATION
# ============================================================================
VITE_APP_NAME=Empowise
VITE_APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:5173/api
